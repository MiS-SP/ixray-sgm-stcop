; Fake Missiles and Grenades
;-------------------------------------------------------------------------------

[wpn_fake_og-7b]:ammo_base,wpn_rpg7_sounds
GroupControlSection         	= spawn_group
discovery_dependency        	=
visual							= dynamics\weapons\wpn_rpg7\wpn_rpg7_grenade.ogf
cform							= skeleton
class							= G_RPG7
$prefetch 						= 32

inv_weight						= 0

cost							= 200

blast							= 2
blast_r							= 4
blast_impulse					= 350
blast_impulse_factor 			= 1

frags							= 8
frags_r							= 20.44
frag_hit						= 5.30
frag_hit_impulse				= 10
frag_ap							= 5.76

hit_type_blast					= explosion
hit_type_frag					= fire_wound

up_throw_factor					= 0.25

explode_particles				= explosions\explosion_04

light_color						= 1.9,1.4,0.5
light_range		 				= 24.0
light_time 		 				= 1.28
	
ph_mass			 				= 3

jump_height 					= 0

wm_size							= 0.5

fragment_speed	 				= 150
explode_duration		 		= 5

wallmark_section				= explosion_marks	

inv_name						= "Og-7b"
inv_name_short					= "Og-7b"
inv_weight						= .2

inv_grid_width					= 4
inv_grid_height					= 1
inv_grid_x						= 15
inv_grid_y						= 5

kill_msg_x						= 0
kill_msg_y						= 85
kill_msg_width					= 74
kill_msg_height					= 19

;- Свойства CustomRocket -------------------------------------------------------
engine_present					= true		;присутствует ли в ракете двигатель
engine_work_time				= 3000		;времЯ работы двигателЯ (в милисекундах)
engine_impulse					= 300
engine_impulse_up				= 133.906	;137.34	= 2*9.81*7 - значение этого параметра (который ЯвлЯетсЯ некой подъемной силой, вопреки названию),
											;при котором ракета массой 7кг не опускаетсЯ под дейсвием
											;гравитации. 2*9.81=19.62 - ускорение свободного падениЯ в мире сталкеров
											;при меньших значениЯх ракета будет опускатьсЯ, при больших подниматьсЯ
lights_enabled 				= true		;свет вокруг ракеты, во времЯ полета
trail_light_color 				= 0.6,0.5,0.3
trail_light_range 				= 15.0

engine_particles 				= weapons\rpg_trail_00
;fly_particles	 			= weapons\rpg_trail_01

force_explode_time			= 30000		; msec

